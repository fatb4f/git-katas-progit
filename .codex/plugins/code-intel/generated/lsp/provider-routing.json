{
  "schema": "git-katas-progit.code-intel.provider-routing.v1",
  "profile": "cue-lsp-only",
  "defaultProvider": "cue-lsp",
  "providers": [
    {
      "id": "cue-lsp",
      "routes": [
        "index.cue",
        "modules/**/*.cue"
      ],
      "authority": false,
      "evidenceOnly": true
    }
  ],
  "excludedProviders": [
    "markdown-lsp",
    "git-analysis",
    "fixture-runner",
    "lua-language-server",
    "wezterm-types",
    "nvim-types",
    "mcp-mutation"
  ]
}
